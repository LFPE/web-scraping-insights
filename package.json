{
  "name": "propintel",
  "version": "1.0.0",
  "private": true,
  "description": "Property Intelligence Platform (PropIntel) Monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "echo 'Run specific scripts using npm run <script> -w <workspace>'",
    "lint": "npm run lint --workspaces --if-present",
    "build": "npm run build --workspaces --if-present"
  },
  "devDependencies": {
    "prisma": "^6.19.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  }
}
